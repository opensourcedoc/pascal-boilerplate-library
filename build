#!/bin/sh

if ! command -v fpc >/dev/null 2>&1; then
    echo "No Free Pascal on the system" >&2
    exit 1
fi

CWD=$(cd "$(dirname "$0")" && pwd)

. "${CWD}/setting.sh"

mkdir -p "$LIB_DIR"
mkdir -p "$OBJ_DIR"

COMPILE_MODE=$(echo "$1" | tr 'abcdefghijklmnopqrstuvwxyz' 'ABCDEFGHIJKLMNOPQRSTUVWXYZ')
if [ "$COMPILE_MODE" = "DEBUG" ]; then
    COMPILER_FLAG="-dDEBUG -g -gl -Cr -Ct -Co -Ci -Sa"
else
    COMPILER_FLAG="-O2 -Xs -CX -XX"
fi

FPC_FLAGS="${FPC_FLAGS:-}"

if [ -n "$FPC_FLAGS" ] || [ -n "$COMPILER_FLAG" ]; then
    set -- $FPC_FLAGS $COMPILER_FLAG
else
    set -- ""
fi

[ "$1" = "" ] && shift

fpc "$@" \
    "-o${LIB_DIR}/${DYNAMIC_LIBRARY}" \
    "-Fu$SRC_DIR" \
    "-Fi$INCLUDE_DIR" \
    "-FU$OBJ_DIR" \
    "-FE$LIB_DIR" \
    "${SRC_DIR}/${ENTRY}"